        "id": "c101",
        "title": "E-commerce Refund",
        "persona": "consumer",
        "category": "Consumer Protection",
        "desc": "Defective goods or non-delivery recovery.",
        "steps": [
            {
                "title": "FORMAL PLATFORM ESCALATION",
                "logic": "Under the Consumer Protection (E-Commerce) Rules 2020, every platform must have a Grievance Redressal Officer. Your first statutory step is to file a complaint via the app and collect a 'Ticket ID'. If the Customer Support bot gives generic replies, find the specific email of the Nodal Officer on their 'Contact Us' page and send a formal 'Notice of Dispute'.",
                "objective": "Triggering internal platform redressal",
                "checklist": [
                    "Collect Order ID and Ticket ID",
                    "Record Unboxing Video if applicable",
                    "Email the Nodal Grievance Officer"
                ],
                "docs": [
                    "Email Record",
                    "Screenshot of Ticket"
                ]
            },
            {
                "title": "NATIONAL CONSUMER HELPLINE",
                "logic": "If the platform denies the refund, lodge a complaint with the National Consumer Helpline (NCH) by calling 1915 or via the 'e-Daakhil' portal. NCH acts as an intermediary and has a high success rate in refund cases. If the company is listed as a 'Partner Company', the NCH grievance carries significant statutory weight in future court proceedings.",
                "objective": "Pre-litigation government mediation",
                "checklist": [
                    "Register on NCH (1915)",
                    "Link your Order Ticket ID",
                    "Wait for 7-day response period"
                ],
                "docs": [
                    "NCH Grievance Receipt"
                ]
            },
            {
                "title": "CONSUMER COMMISSION FILING",
                "logic": "If mediation fails, you must file a formal Consumer Complaint in the District Commission under Section 35 of the CPA 2019. For claims under \u20b950 Lakhs, the District Commission has jurisdiction. You can represent yourself without a lawyer. Specify the 'Deficiency in Service' and 'Unfair Trade Practice' clearly to claim your refund plus compensation for mental agony.",
                "objective": "Judicial recovery of funds",
                "checklist": [
                    "Draft Section 35 Complaint",
                    "Attach all NCH and Support emails",
                    "File via e-Daakhil for speed"
                ],
                "docs": [
                    "Legal Notice",
                    "Consumer Complaint Draft"
                ]
            }
        ]
    },
