    {
        "id": "c125",
        "title": "Animal Rights FIR",
        "persona": "consumer",
        "category": "Consumer Protection",
        "desc": "Action for street abuse or cruelty.",
        "steps": [
            {
                "title": "IMMEDIATE ON-SITE ACTION",
                "logic": "If you witness animal cruelty, your first statutory action is to record evidence (video/photos) and stop the act if safe. Call the local police (100 or 112) and the nearest NGO. Under Section 11 of the PCA Act 1960, animal abuse is a punishable offense. You must demand the police to rescue the animal immediately under 'Emergency Veterinary Necessity' and preserve the scene.",
                "objective": "Securing the animal and evidence",
                "checklist": [
                    "Record video/photo evidence",
                    "Call local police for intervention",
                    "Alert nearby Animal Welfare NGO"
                ],
                "docs": [
                    "Evidence Photo/Video Log"
                ]
            },
            {
                "title": "STATUTORY FIR REGISTRATION",
                "logic": "The police are legally bound to register an FIR for animal cruelty under IPC Sections 428/429 (Mischief) and the PCA Act. If the officer refuses, you must cite the DGP's advisory or escalate to the Senior Superintendent of Police (SSP). Do not settle for a 'DDR' (Daily Diary Report); insist on an FIR to ensure a criminal investigation. You can also file a private complaint in the Magistrate court if police inaction persists.",
                "objective": "Activating criminal law machinery",
                "checklist": [
                    "Cite IPC 428/429 to the officer",
                    "Demand FIR copy (Free of cost)",
                    "Escalate to SSP if FIR refused"
                ],
                "docs": [
                    "FIR Copy",
                    "Written Complaint"
                ]
            },
            {
                "title": "VETERINARY FORENSIC AUDIT",
                "logic": "The animal must be examined by a Government Veterinarian to establish 'Clinical Evidence' of cruelty. This Medico-Legal Certificate (MLC) is the backbone of your case. Ensure the doctor specifies the nature of injuries and the 'Instrument of Injury'. Without a formal medical report, the case will collapse in court during the trial phase.",
                "objective": "Establishing clinical proof of abuse",
                "checklist": [
                    "Transfer animal to Govt Vet Clinic",
                    "Request MLC medical report",
                    "Ensure 'Forensic Nature' is mentioned"
                ],
                "docs": [
                    "Veterinary MLC Report",
                    "Post-Mortem (if applicable)"
                ]
            }
        ]
    },
