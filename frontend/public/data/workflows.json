    {
        "id": "s101",
        "title": "UGC Fee Refund",
        "persona": "student",
        "category": "Academic & Campus",
        "desc": "Full refund on seat exit per 2023 rules.",
        "steps": [
            {
                "title": "Filing a Formal Refund Request & Statutory Notice",
                "logic": "The first step is to submit a written application to the Registrar or the Head of the Institution. You must explicitly mention the UGC Notification on Refund of Fees (2023). Under these rules, colleges cannot withhold your original certificates and must refund your fees in full if you withdraw your admission before the deadline specified by the UGC. This establishes your legal standing for any future escalation.",
                "objective": "Actuating your legal right to a refund",
                "checklist": [
                    "Send notice via Registered Post or Email",
                    "Keep a copy of the acknowledgment receipt",
                    "Cite Section 4.1 of the 2023 UGC Notification"
                ],
                "docs": [
                    "UGC Fee Refund Notification (Current Academic Year)"
                ]
            },
            {
                "title": "Escalation to the University Student Grievance Redressal Committee (SGRC)",
                "logic": "If the institution fails to respond or denies your refund within 15 days, you should approach the SGRC. This is a mandatory internal committee defined under the UGC Regulations 2023. They are obligated to hear your case and provide a resolution within a specific timeframe. This step is crucial because the University Ombudsman will usually require proof that you first tried to resolve it through the SGRC.",
                "objective": "Using internal statutory grievance mechanisms",
                "checklist": [
                    "Draft a detailed complaint with the SGRC",
                    "Attach proof of your initial refund request",
                    "Request a formal hearing or written response"
                ],
                "docs": [
                    "SGRC Complaint Acknowledgment"
                ]
            },
            {
                "title": "Filing a Complaint with the University Ombudsman or Consumer Court",
                "logic": "If the SGRC's decision is unsatisfactory, you can appeal to the University Ombudsman. Simultaneously, because education is increasingly viewed as a 'service' under the Consumer Protection Act 2019 (depending on the specific circumstances of the institution), you can file a complaint with the District Consumer Commission for 'Deficiency in Service'. For government universities, you also have the option of filing a Writ of Mandamus in the High Court under Article 226 to compel them to follow UGC guidelines.",
                "objective": "Enforcing statutory compliance through judicial authorities",
                "checklist": [
                    "Prepare the Ombudsman Appeal Form",
                    "Draft a Legal Notice via a lawyer for Consumer Court",
                    "Attach all previous correspondence as evidence"
                ],
                "docs": [
                    "Consumer Court Petition / Writ Draft"
                ]
            }
        ]
    },
    {
        "id": "s102",
        "title": "Ragging FIR",
        "persona": "student",
        "category": "Academic & Campus",
        "desc": "Criminal action for institutional abuse.",
        "steps": [
            {
                "title": "Immediate Incident Reporting & Anti-Ragging Committee (ARC) Activation",
                "logic": "You must immediately report any incident of ragging to the Anti-Ragging Committee of your college. According to the UGC Regulations 2009, every institution MUST have an ARC and an Anti-Ragging Squad. The committee is legally bound to investigate the matter within 24 hours. Ensuring this is documented is vital for holding the institution itself liable for negligence if they fail to protect you.",
                "objective": "Initiating institutional accountability",
                "checklist": [
                    "Identify the perpetrators and witnesses",
                    "Note the exact date, time, and nature of the abuse",
                    "Submit a formal written complaint to the ARC head"
                ],
                "docs": [
                    "UGC Anti-Ragging Regulations 2009"
                ]
            },
            {
                "title": "Mandatory Lodging of a First Information Report (FIR) under Section 154 CrPC",
                "logic": "Ragging is not just an institutional issue; it is a crime under the Indian Penal Code (IPC). You should visit the nearest Police Station to lodge an FIR. If the college authorities refuse to help you, they are in violation of the Supreme Court's mandate in the 'Vishwa Jagriti Mission' case. The FIR puts the state machinery into action and ensures that the perpetrators face criminal prosecution for acts like physical hurt (Sec 323) or criminal intimidation (Sec 506).",
                "objective": "Triggering the criminal justice system",
                "checklist": [
                    "Provide a detailed statement to the SHO",
                    "Ensure the FIR is registered under relevant IPC sections",
                    "Obtain a free signed copy of the FIR immediately"
                ],
                "docs": [
                    "Certified FIR Copy"
                ]
            },
            {
                "title": "Reporting to the National Anti-Ragging Helpline & Judicial Follow-up",
                "logic": "Beyond the local police, you must report the incident to the National Anti-Ragging Helpline (1800-180-5522). This ensures that the UGC is aware of the situation and can take punitive action against the college if necessary. If the police fail to investigate properly, you can file a 'Protest Petition' in court or approach the High Court under Article 226 for a court-monitored investigation.",
                "objective": "Ensuring comprehensive legal and administrative protection",
                "checklist": [
                    "Call the 24/7 National Anti-Ragging Helpline",
                    "Follow up with the UGC's monitoring agency",
                    "Consult a lawyer for potential civil damages"
                ],
                "docs": [
                    "UGC Compliance Report / Court Petition"
                ]
            }
        ]
    },
